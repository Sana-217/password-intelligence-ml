{
  "manifest_version": 3,
  "name": "PassGuard",
  "version": "1.0",
  "description": "AI-Based Secure & Memorable Password Generator — generate passwords from your personal phrases directly in the browser.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PassGuard — AI Password Generator",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*"
  ]
}
